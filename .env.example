APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
SCHEDULER_LOG_LEVEL=info
SCHEDULER_LOG_DAYS=30
QUEUE_MONITOR_LOG_LEVEL=info
QUEUE_MONITOR_LOG_DAYS=30
EOD_REPAIR_LOG_LEVEL=info
EOD_REPAIR_LOG_DAYS=30

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gex_profile
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_MONITOR_ENABLED=true
QUEUE_MONITOR_CONNECTION=database
QUEUE_MONITOR_QUEUES=default,intraday,intraday-heavy,calculator,quotes
QUEUE_MONITOR_MAX_SIZE=250

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MASSIVE_API_KEY=
MASSIVE_BASE=https://api.massive.com
MASSIVE_AUTH_MODE=header
MASSIVE_API_HEADER=X-API-Key
MASSIVE_API_QUERY=apiKey

CALC_CHAIN_MAX_PAGES=150
CALC_CHAIN_MAX_PAGES_LARGE=350
EOD_CHAIN_MAX_PAGES=120
EOD_CHAIN_PAGE_LIMIT=250
EOD_CHAIN_MAX_PAGES_PER_EXPIRY=80
EOD_CHAIN_MAX_HINT_EXPIRIES=40
EOD_CHAIN_REPAIR_PARTIAL_EXPIRIES=true
EOD_STRIKE_BAND_PCT=2.0
EOD_GREEKS_NEAR_PCT=2.0
EOD_MIN_KEEP_OI=1
EOD_MIN_KEEP_VOL=1
