# Copy this file to .env.testing, then run `composer test:mysql`.
# The guarded command requires DB_DATABASE to end with `_test`.
# Laravel's RefreshDatabase trait may drop every table in this database.

APP_NAME=GEXoptions
APP_ENV=testing
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

BCRYPT_ROUNDS=4
LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gex_test
DB_USERNAME=gex_test
DB_PASSWORD=gex_test

CACHE_STORE=array
QUEUE_CONNECTION=sync
QUEUE_MONITOR_ENABLED=false
SESSION_DRIVER=array
MAIL_MAILER=array

MASSIVE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
STEADY_API_KEY=
